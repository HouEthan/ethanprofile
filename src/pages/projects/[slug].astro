---
import DetailArticle from "../../components/DetailArticle.astro";
import SiteShell from "../../components/SiteShell.astro";
import { projects } from "../../data/site";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<SiteShell title={`${project.title} | Projects`} description={project.summary}>
  <DetailArticle
    title={project.title}
    summary={project.summary}
    meta={[project.year, project.role, `分類：${project.category}`, ...project.stack]}
    highlights={project.highlights}
    content={project.content}
  />
</SiteShell>
