---
import CardGrid from "../../components/CardGrid.astro";
import CategoryStrip from "../../components/CategoryStrip.astro";
import HeroSection from "../../components/HeroSection.astro";
import SiteShell from "../../components/SiteShell.astro";
import { projectCategories, projects } from "../../data/site";
---

<SiteShell title="Projects | Ethan Profile" description="所有專案與分類整理">
  <HeroSection
    eyebrow="Projects"
    title="所有專案"
    description="這裡整理完整專案列表，並保留分類變數，方便之後擴充更多作品類型。"
  >
    <div class="panel info-panel">
      <h2>{projects.length} 個專案</h2>
      <p>目前已支援使用 `category` 做分類，未來可直接擴充篩選或分頁。</p>
    </div>
  </HeroSection>

  <CategoryStrip title="專案分類" categories={projectCategories} />

  <section class="section">
    <CardGrid
      items={projects.map((project) => ({
        href: `/projects/${project.slug}`,
        title: project.title,
        summary: project.summary,
        meta: `${project.year} | ${project.role}`,
        category: project.category,
        tags: project.stack,
      }))}
    />
  </section>
</SiteShell>

<style>
  .info-panel {
    padding: 24px;
  }

  .info-panel h2 {
    margin: 0 0 12px;
  }

  .info-panel p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }
</style>
