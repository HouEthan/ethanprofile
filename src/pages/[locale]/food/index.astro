---
import CardGrid from "../../../components/CardGrid.astro";
import HeroSection from "../../../components/HeroSection.astro";
import LocalizedCategoryStrip from "../../../components/LocalizedCategoryStrip.astro";
import SiteShell from "../../../components/SiteShell.astro";
import { foodCategories, foods } from "../../../data/content/food";
import { locales, type Locale } from "../../../i18n/config";
import { t } from "../../../i18n/dictionary";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
---

<SiteShell locale={locale} pathname="/food" title={`${t(locale, "nav.food")} | ${t(locale, "brand")}`} description={t(locale, "archive.foodDescription")}>
  <HeroSection eyebrow={t(locale, "sections.food")} title={t(locale, "archive.foodTitle")} description={t(locale, "archive.foodDescription")}>
    <div class="panel info-panel">
      <h2>{foods.length} {t(locale, "archive.foodCount")}</h2>
      <p>{t(locale, "archive.foodSummary")}</p>
    </div>
  </HeroSection>

  <LocalizedCategoryStrip
    eyebrow={t(locale, "sections.categories")}
    title={t(locale, "archive.foodCategories")}
    categories={foodCategories.map((category) => t(locale, `categories.${category}`))}
  />

  <section class="section">
    <CardGrid
      items={foods.map((item) => ({
        href: `/${locale}/food/${item.slug}`,
        title: t(locale, item.titleKey),
        summary: t(locale, item.summaryKey),
        meta: t(locale, item.locationKey),
        category: t(locale, `categories.${item.category}`),
        tags: item.tagKeys.map((key) => t(locale, key)),
      }))}
    />
  </section>
</SiteShell>

<style>
  .info-panel {
    padding: 24px;
  }

  .info-panel h2 {
    margin: 0 0 12px;
  }

  .info-panel p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }
</style>
