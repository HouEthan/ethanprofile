---
import { Image } from "astro:assets";
import CardGrid from "../../components/CardGrid.astro";
import HeroSection from "../../components/HeroSection.astro";
import SiteShell from "../../components/SiteShell.astro";
import { profileBase, profileContent } from "../../data/content/profile-data";
import { featuredProjects } from "../../data/content/projects";
import { locales, type Locale } from "../../i18n/config";
import { t } from "../../i18n/dictionary";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const profileText = profileContent[locale];

const labels = {
  zh: {
    skills: "核心能力",
    cert: "證照",
    exp: "經歷",
    certTitle: "CEH",
    certOrg: "EC-Council",
    certMeta: "Certified Ethical Hacker",
    certAction: "查看證照 PDF",
  },
  en: {
    skills: "Skills",
    cert: "Certification",
    exp: "Experience",
    certTitle: "CEH",
    certOrg: "EC-Council",
    certMeta: "Certified Ethical Hacker",
    certAction: "Open certificate PDF",
  },
  ja: {
    skills: "スキル",
    cert: "資格",
    exp: "経歴",
    certTitle: "CEH",
    certOrg: "EC-Council",
    certMeta: "Certified Ethical Hacker",
    certAction: "証明書 PDF を開く",
  },
} as const;
---

<SiteShell locale={locale} pathname="/about" title={`${t(locale, "nav.about")} | ${t(locale, "brand")}`} description={t(locale, "about.description")}>
  <HeroSection
    eyebrow={t(locale, "about.eyebrow")}
    title={t(locale, "about.title")}
    description={t(locale, "about.description")}
    actions={[{ href: `/${locale}/projects`, label: t(locale, "about.browseProjects") }]}
  >
    <div class="panel about-side">
      <Image src={profileBase.portraitPhoto} alt={profileBase.name} class="portrait" />
      <h2>{profileBase.name}</h2>
      <p>{profileText.title}</p>
      <p>{profileText.location}</p>
      <a href={`mailto:${profileBase.email}`}>{profileBase.email}</a>
    </div>
  </HeroSection>

  <section class="section about-grid">
    <div class="content-card bio">
      <span class="eyebrow">{t(locale, "sections.profile")}</span>
      <h2>{t(locale, "about.profile")}</h2>
      {profileText.about.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
    <div class="content-card bio">
      <span class="eyebrow">{t(locale, "sections.focus")}</span>
      <h2>{t(locale, "about.focus")}</h2>
      <ul>
        {profileText.focusAreas.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section credentials-grid">
    <div class="content-card bio">
      <span class="eyebrow">Skills</span>
      <h2>{labels[locale].skills}</h2>
      <div class="chip-list">
        {profileText.skills.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
    </div>

    <div class="content-card bio cert-card">
      <span class="eyebrow">Certification</span>
      <h2>{labels[locale].cert}</h2>
      <div class="certificate">
        <div>
          <p class="cert-org">{labels[locale].certOrg}</p>
          <h3>{labels[locale].certTitle}</h3>
          <p class="cert-meta">{labels[locale].certMeta}</p>
        </div>
        <a href="/certificates/ceh.pdf" class="cert-link" target="_blank" rel="noreferrer">
          {labels[locale].certAction}
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="content-card bio">
      <span class="eyebrow">Experience</span>
      <h2>{labels[locale].exp}</h2>
      <ul>
        {profileText.experience.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <span class="eyebrow">{t(locale, "sections.featured")}</span>
      <h2>{t(locale, "about.featuredProjects")}</h2>
    </div>
    <CardGrid
      items={featuredProjects.map((project) => ({
        href: `/${locale}/projects/${project.slug}`,
        title: t(locale, project.titleKey),
        summary: t(locale, project.summaryKey),
        meta: t(locale, project.roleKey),
        category: project.year,
        tags: project.stack,
      }))}
    />
  </section>
</SiteShell>

<style>
  .about-side {
    display: grid;
    gap: 10px;
    padding: 20px;
    align-content: start;
  }

  .portrait {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 22px;
  }

  .about-side h2,
  .bio h2,
  .section-head h2 {
    margin: 8px 0 12px;
  }

  .about-side p,
  .bio p,
  .bio li {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.95fr);
    gap: 18px;
  }

  .credentials-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.85fr);
    gap: 18px;
    align-items: stretch;
  }

  .bio {
    padding: 24px;
  }

  .bio ul {
    margin: 0;
    padding-left: 20px;
  }

  .bio li + li,
  .bio p + p {
    margin-top: 8px;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(33, 22, 15, 0.12);
    background: rgba(255, 255, 255, 0.84);
    color: var(--text);
    font-weight: 700;
  }

  .cert-card {
    display: flex;
    flex-direction: column;
  }

  .certificate {
    display: grid;
    gap: 18px;
    margin-top: 10px;
    padding: 18px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(33, 22, 15, 0.08);
  }

  .certificate h3 {
    margin: 6px 0 8px;
    font-size: 1.45rem;
  }

  .cert-org,
  .cert-meta {
    margin: 0;
  }

  .cert-org {
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .cert-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(33, 22, 15, 0.14);
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.92);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .cert-link:hover {
    transform: translateY(-1px);
    border-color: rgba(154, 78, 131, 0.32);
    background: rgba(255, 255, 255, 1);
  }

  @media (max-width: 860px) {
    .about-grid,
    .credentials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
