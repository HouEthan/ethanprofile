---
import { Image } from "astro:assets";
import CardGrid from "../../components/CardGrid.astro";
import HeroSection from "../../components/HeroSection.astro";
import SiteShell from "../../components/SiteShell.astro";
import { profileBase, profileContent } from "../../data/content/profile";
import { featuredProjects } from "../../data/content/projects";
import { locales, type Locale } from "../../i18n/config";
import { t } from "../../i18n/dictionary";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const profileText = profileContent[locale];

const copy = {
  zh: {
    title: "關於我",
    description: "這一頁把履歷中的重點內容重新整理成比較適合網站閱讀的版本，包含自介、技能、學歷、證照與實務經驗。",
    eyebrow: "About",
    profile: "個人簡介",
    focus: "目前關注",
    skills: "核心能力",
    cert: "證照",
    education: "學歷與研究",
    exp: "實務經驗",
    highlights: "重要亮點",
    featured: "精選專案",
    browseProjects: "瀏覽所有專案",
    certAction: "查看證照 PDF",
  },
  en: {
    title: "About",
    description: "This page turns resume content into a more readable website format, covering profile, skills, education, certification, and practical experience.",
    eyebrow: "About",
    profile: "Profile",
    focus: "Current focus",
    skills: "Skills",
    cert: "Certification",
    education: "Education & Research",
    exp: "Experience",
    highlights: "Highlights",
    featured: "Featured projects",
    browseProjects: "Browse all projects",
    certAction: "Open certificate PDF",
  },
  ja: {
    title: "About",
    description: "履歴書の内容を、プロフィール、スキル、学歴、資格、実務経験として読みやすく整理したページです。",
    eyebrow: "About",
    profile: "プロフィール",
    focus: "現在の関心",
    skills: "スキル",
    cert: "資格",
    education: "学歴・研究",
    exp: "実務経験",
    highlights: "ハイライト",
    featured: "注目プロジェクト",
    browseProjects: "すべてのプロジェクトを見る",
    certAction: "証明書 PDF を開く",
  },
} as const;

const ui = copy[locale];
---

<SiteShell locale={locale} pathname="/about" title={`${ui.title} | Ethan Profile`} description={ui.description}>
  <HeroSection eyebrow={ui.eyebrow} title={ui.title} description={ui.description} actions={[{ href: `/${locale}/projects`, label: ui.browseProjects }]}>
    <div class="panel about-side">
      <Image src={profileBase.portraitPhoto} alt={profileBase.name} class="portrait" />
      <h2>{profileBase.name}</h2>
      <p>{profileText.title}</p>
      <p>{profileText.location}</p>
      <a href={`mailto:${profileBase.email}`}>{profileBase.email}</a>
    </div>
  </HeroSection>

  <section class="section two-col">
    <div class="content-card bio">
      <span class="eyebrow">{ui.profile}</span>
      <h2>{ui.profile}</h2>
      {profileText.about.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>

    <div class="content-card bio">
      <span class="eyebrow">{ui.focus}</span>
      <h2>{ui.focus}</h2>
      <ul>
        {profileText.focusAreas.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section two-col">
    <div class="content-card bio">
      <span class="eyebrow">{ui.skills}</span>
      <h2>{ui.skills}</h2>
      <div class="chip-list">
        {profileText.skills.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
    </div>

    <div class="content-card bio cert-card">
      <span class="eyebrow">{ui.cert}</span>
      <h2>{ui.cert}</h2>
      <div class="certificate">
        <div>
          {profileText.certifications.map((item) => (
            <p class="cert-name">{item}</p>
          ))}
        </div>
        <a href="/certificates/ceh.pdf" class="cert-link" target="_blank" rel="noreferrer">
          {ui.certAction}
        </a>
      </div>
    </div>
  </section>

  <section class="section two-col">
    <div class="content-card bio">
      <span class="eyebrow">{ui.education}</span>
      <h2>{ui.education}</h2>
      <ul>
        {profileText.education.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div class="content-card bio">
      <span class="eyebrow">{ui.highlights}</span>
      <h2>{ui.highlights}</h2>
      <ul>
        {profileText.highlights.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="content-card bio">
      <span class="eyebrow">{ui.exp}</span>
      <h2>{ui.exp}</h2>
      <ul>
        {profileText.experience.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <span class="eyebrow">{ui.featured}</span>
      <h2>{ui.featured}</h2>
    </div>
    <CardGrid
      items={featuredProjects.map((project) => ({
        href: `/${locale}/projects/${project.slug}`,
        title: t(locale, project.titleKey),
        summary: t(locale, project.summaryKey),
        meta: t(locale, project.roleKey),
        category: project.year,
        tags: project.stack,
      }))}
    />
  </section>
</SiteShell>

<style>
  .about-side {
    display: grid;
    gap: 10px;
    padding: 20px;
    align-content: start;
  }

  .portrait {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 22px;
  }

  .about-side h2,
  .bio h2,
  .section-head h2 {
    margin: 8px 0 12px;
  }

  .about-side p,
  .bio p,
  .bio li {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .two-col {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 18px;
  }

  .bio {
    padding: 24px;
  }

  .bio ul {
    margin: 0;
    padding-left: 20px;
  }

  .bio li + li,
  .bio p + p {
    margin-top: 10px;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(33, 22, 15, 0.12);
    background: rgba(255, 255, 255, 0.84);
    color: var(--text);
    font-weight: 700;
  }

  .certificate {
    display: grid;
    gap: 18px;
    margin-top: 10px;
    padding: 18px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(33, 22, 15, 0.08);
  }

  .cert-name {
    font-weight: 700;
    color: var(--text) !important;
  }

  .cert-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(33, 22, 15, 0.14);
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.92);
  }

  @media (max-width: 860px) {
    .two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
