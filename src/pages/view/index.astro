---
import CardGrid from "../../components/CardGrid.astro";
import CategoryStrip from "../../components/CategoryStrip.astro";
import HeroSection from "../../components/HeroSection.astro";
import SiteShell from "../../components/SiteShell.astro";
import { viewCategories, views } from "../../data/site";
---

<SiteShell title="View | Ethan Profile" description="所有景點內容與分類整理">
  <HeroSection
    eyebrow="View"
    title="所有景點"
    description="這裡整理景點與行程內容，保留分類欄位，之後可以自由延伸成旅遊或主題路線。"
  >
    <div class="panel info-panel">
      <h2>{views.length} 個景點</h2>
      <p>目前分類支援城市散步、山海景點與展覽空間，未來可再依城市或旅程主題拆分。</p>
    </div>
  </HeroSection>

  <CategoryStrip title="景點分類" categories={viewCategories} />

  <section class="section">
    <CardGrid
      items={views.map((item) => ({
        href: `/view/${item.slug}`,
        title: item.title,
        summary: item.summary,
        meta: item.location,
        category: item.category,
        tags: item.tags,
      }))}
    />
  </section>
</SiteShell>

<style>
  .info-panel {
    padding: 24px;
  }

  .info-panel h2 {
    margin: 0 0 12px;
  }

  .info-panel p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }
</style>
