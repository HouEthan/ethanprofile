---
interface CardItem {
  href: string;
  title: string;
  summary: string;
  meta?: string;
  category?: string;
  tags?: string[];
}

interface Props {
  items: CardItem[];
}

const { items } = Astro.props;

function getTone(category?: string) {
  switch (category?.toLowerCase()) {
    case "featured":
    case "精選專案":
      return { accent: "#7f4a86", soft: "#f2e8f5", line: "#a77eb0" };
    case "content":
    case "內容策略":
      return { accent: "#8b5a2b", soft: "#f6ead8", line: "#b98a55" };
    case "branding":
    case "品牌敘事":
      return { accent: "#5d4ba8", soft: "#ece9fb", line: "#8677c7" };
    case "web":
    case "網站設計":
      return { accent: "#2b6a78", soft: "#e4f1f4", line: "#68a2af" };
    default:
      return { accent: "#7b4b36", soft: "#f3e8e1", line: "#b27f67" };
  }
}
---

<div class="grid-3 project-grid">
  {items.map((item) => {
    const tone = getTone(item.category);

    return (
      <a href={item.href} class="content-card card-link" style={`--card-accent:${tone.accent}; --card-soft:${tone.soft}; --card-line:${tone.line};`}>
        <div class="card-preview">
          <div class="card-preview-head">
            <div>
              {item.category && <p class="preview-kicker">{item.category}</p>}
              <h2>{item.title}</h2>
              {item.summary && <p class="preview-copy">{item.summary}</p>}
            </div>
            <span class="preview-mark">★</span>
          </div>

          <div class="mockup">
            <div class="mock-window is-back"></div>
            <div class="mock-window is-front">
              <div class="mock-toolbar"></div>
              <div class="mock-body">
                <div class="mock-card"></div>
                <div class="mock-chart"></div>
                <div class="mock-list">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card-body">
          {item.meta && <p class="card-meta">{item.meta}</p>}
          <h3>{item.title}</h3>
          <p class="card-summary">{item.summary}</p>
          {item.tags && (
            <div class="card-tags">
              {item.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          )}
        </div>
      </a>
    );
  })}
</div>

<style>
  .project-grid {
    align-items: stretch;
  }

  .card-link {
    display: grid;
    overflow: hidden;
    padding: 0;
    text-decoration: none;
    border-radius: 18px;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .card-link:hover {
    transform: translateY(-4px);
    box-shadow: 0 26px 50px rgba(54, 34, 23, 0.14);
    border-color: color-mix(in srgb, var(--card-accent) 22%, white);
  }

  .card-preview {
    display: grid;
    gap: 14px;
    padding: 18px 18px 0;
    background: linear-gradient(180deg, var(--card-soft) 0%, color-mix(in srgb, var(--card-soft) 78%, white) 100%);
    border-bottom: 4px solid var(--card-line);
  }

  .card-preview-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: start;
  }

  .preview-kicker {
    margin: 0 0 6px;
    color: var(--card-accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .card-preview h2 {
    margin: 0;
    color: var(--card-accent);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .preview-copy {
    margin: 6px 0 0;
    color: color-mix(in srgb, var(--card-accent) 78%, #2d2018);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .preview-mark {
    color: var(--card-accent);
    font-size: 0.9rem;
    line-height: 1;
  }

  .mockup {
    position: relative;
    height: 170px;
    overflow: hidden;
  }

  .mock-window {
    position: absolute;
    bottom: 0;
    border-radius: 12px 12px 0 0;
    border: 1px solid rgba(25, 17, 11, 0.12);
    background: #fffdfb;
    box-shadow: 0 12px 24px rgba(20, 14, 10, 0.22);
  }

  .mock-window.is-back {
    left: 4%;
    width: 46%;
    height: 98px;
    background:
      linear-gradient(180deg, rgba(37, 24, 18, 0.18), rgba(37, 24, 18, 0.06)),
      #efe9e4;
  }

  .mock-window.is-front {
    right: 0;
    width: 74%;
    height: 150px;
    overflow: hidden;
  }

  .mock-toolbar {
    height: 18px;
    background: color-mix(in srgb, var(--card-soft) 60%, #f8f5f1);
    border-bottom: 1px solid rgba(25, 17, 11, 0.08);
  }

  .mock-body {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 12px;
    padding: 12px;
  }

  .mock-card,
  .mock-chart,
  .mock-list span {
    border-radius: 10px;
    background: color-mix(in srgb, var(--card-accent) 10%, white);
  }

  .mock-card {
    height: 88px;
  }

  .mock-chart {
    height: 56px;
  }

  .mock-list {
    display: grid;
    gap: 8px;
    grid-column: 2;
  }

  .mock-list span {
    height: 10px;
  }

  .card-body {
    display: grid;
    gap: 12px;
    padding: 16px 18px 18px;
    background: rgba(255, 253, 249, 0.92);
  }

  .card-meta {
    margin: 0;
    color: #8d7d70;
    font-size: 0.92rem;
  }

  .card-body h3 {
    margin: 0;
    color: var(--card-accent);
    font-size: 1.1rem;
    line-height: 1.35;
  }

  .card-summary {
    margin: 0;
    color: var(--text);
    line-height: 1.7;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .card-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(33, 22, 15, 0.12);
    background: white;
    color: #1f1610;
    font-size: 0.84rem;
  }
</style>
